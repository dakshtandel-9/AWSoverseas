# Supabase — Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Admin login
ADMIN_PASSWORD=123456789
# Long random string used to sign the admin session cookie — generate with
# `openssl rand -hex 32`. Do NOT reuse ADMIN_PASSWORD here.
SESSION_SECRET=

# Cloudinary — Dashboard home page (cloud name), Settings -> Access Keys (API key/secret)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

CLOUDINARY_API_KEY =

CLOUDINARY_API_SECRET =